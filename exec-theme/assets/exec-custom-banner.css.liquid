.exec-banner {
    background-color: {{ settings.banner_background_color }};
    padding: 20px;
    text-align: center;
    border: 1px solid #ddd;
}

.exec-banner h1 {
    font-size: 2rem;
    color: {{ settings.banner_text_color }};
}

.exec-banner p {
    font-size: 1.2rem;
    color: {{ settings.banner_text_color }};
}

.exec-banner a {
    display: inline-block;
    margin-top: 10px;
    padding: 10px 20px;
    background-color: {{ settings.banner_button_color }};
    color: #fff;
    text-decoration: none;
    border-radius: 5px;
    transition: background-color 1s ease;
}

.exec-banner a:hover {
    background-color: {{ settings.banner_button_hover_color }};
}
