.related-products-section {
  margin-top: 2rem;
  padding: 2rem 0;
  background-color: {{ settings.recommendations_background_color }};
}

.related-products-heading {
  font-size: 2rem;
  font-weight: bold;
  margin-bottom: 1.5rem;
  text-align: center;
  color: {{ settings.recommendations_heading_color }};
  text-transform: uppercase;
}

#related-products-container {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  justify-content: center; /* Ensures products are centered */
  align-items: flex-start; /* Aligns items to the top of the container */
  margin: 0 auto; /* Centers the container itself */
}

.related-product {
  width: 220px;
  background-color: {{ settings.recommendations_product_background_color }};
  border: 1px solid {{ settings.recommendations_product_border_color }};
  border-radius: 10px;
  padding: 1rem;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  text-align: center;
}

.related-product:hover {
  transform: translateY(-5px);
  box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
}

.related-product img {
  width: 100%;
  height: auto;
  border-radius: 8px;
  object-fit: cover;
  margin-bottom: 1rem;
}

.related-product-title {
  font-size: 1.1rem;
  font-weight: 600;
  color: {{ settings.recommendations_product_title_color }};
  margin-bottom: 0.5rem;
}

.related-product button {
  margin-top: 0.5rem;
  padding: 0.8rem 1.2rem;
  background-color: {{ settings.recommendations_product_button_background_color }};
  color: #fff;
  border: none;
  border-radius: 5px;
  font-size: 1rem;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.related-product button:hover {
  background-color: {{ settings.recommendations_product_button_background_color_onhover }};
}

.loading {
  text-align: center;
  color: {{ settings.recommendations_loading_color }};
  font-size: 1.2rem;
}

@media (max-width: 768px) {
  .related-product {
    width: 45%;
  }
}

@media (max-width: 480px) {
  .related-product {
    width: 90%;
  }
}
