.exec-announcement-bar {
    background-color: {{ settings.bar_background_color }};
    display: flex;
    overflow: hidden;
    margin: 0;
    padding: 10px 0;
}
.exec-announcement-bar-content {
    display: flex;
    width: 100%;
    position: relative;
}
.exec-announcement-bar-marquee {
    display: flex;
    white-space: nowrap;
    transform: translateX(100%);
    animation: scroll-left 10s linear infinite;
}
.exec-announcement-bar-marquee a, .exec-announcement-bar-marquee p {
    color: {{ settings.bar_link_color }};
    position: relative;
    display: inline-block;
    margin-right: 20px;
    text-decoration: none;
    font-size: 1.2rem;
}
@keyframes scroll-left {
    from {
        transform: translateX(100%);
    }
    to {
        transform: translateX(-100%);
    }
}