.product-grid-container {
    display: none;
}
.product-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
    margin-top: 2rem;
    padding: 0 1rem;
    box-sizing: border-box;
}

.product-grid-card {
    width: 512px;
    height: 512px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border-radius: 8px;
    padding: 1rem;
    font-family: "Poetsen One", sans-serif;
    font-weight: 500;
    font-style: normal;
    position: relative;
}

@media (min-width: 1025px) and (max-width: 1136px) {
    .product-grid-card {
        width: 400px;
    }
}

@media (max-width: 1024px) {
    .product-grid-card {
        width: 300px;
    }
}

@media (max-width: 768px) {
    .product-grid-card {
        width: 320px;
    }
}

@media (min-width: 481px) and (max-width: 750px) {
    .product-grid-card {
        width: 80%;
    }
}

@media (max-width: 480px) {
    .product-grid-card {
        width: 100%;
        padding: 0.5rem;
    }
    .sale-tag {
        top: 0.5rem;
        left: 0.5rem;
        font-size: 0.7rem;
        padding: 0.25em 0.5em;
        border-radius: 0.5em;
    }
}

.product-grid-card:hover .product-grid-image {
    transform: scale(1.05);
}

.product-grid-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    margin-bottom: 1rem;
    transition: transform 0.5s ease;
}

.product-grid-title {
    font-size: 1rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
    color: var(--primary-text-color);
}

.product-grid-prices {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: row;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.9rem;
}
.product-grid-card-link {
    position: relative;
    display: block;
    height: 100%;
}

.sale-tag {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    color: var(--primary-text-color);
    font-size: 0.85rem;
    font-weight: bold;
    padding: 0.4em 0.8em;
    border-radius: 0.5em;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    z-index: 2;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    pointer-events: none;
}

@media (max-width: 768px) {
    .sale-tag {
        font-size: 0.75rem;
        padding: 0.3em 0.6em;
    }
}

@media (max-width: 480px) {
    .sale-tag {
        top: 0.5rem;
        left: 0.5rem;
        font-size: 0.7rem;
        padding: 0.25em 0.5em;
        border-radius: 0.5em;
    }
}

.product-grid-card-link,
.product-grid-card-link:visited,
.product-grid-card-link:hover,
.product-grid-card-link:active {
    text-decoration: none;
    color: inherit;
}

.product-grid-price {
    color: var(--primary-text-color);
    font-weight: 800;
}

.product-grid-price-old {
    color: var(--secondary-text-color);
    font-weight: 400;
}

.product-grid-price-new {
    color: var(--primary-text-color);
    font-weight: 800;
}
