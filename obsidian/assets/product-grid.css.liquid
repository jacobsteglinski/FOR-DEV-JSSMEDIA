.product-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 0 1rem;
    box-sizing: border-box;
}

.product-grid-card {
    flex: 0 1 calc(25% - 1rem);
    max-width: calc(25% - 1rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border-radius: 8px;
    padding: 1rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

@media (max-width: 1024px) {
    .product-grid-card {
        flex: 0 1 calc(33.33% - 1rem);
        max-width: calc(33.33% - 1rem);
    }
}

@media (max-width: 768px) {
    .product-grid-card {
        flex: 0 1 calc(50% - 1rem);
        max-width: calc(50% - 1rem);
    }
}

@media (max-width: 480px) {
    .product-grid-card {
        flex: 0 1 calc(100% - 1rem);
        max-width: calc(100% - 1rem);
    }
}

.product-grid-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
}

.product-grid-image {
    width: 100%;
    max-height: 150px;
    object-fit: contain;
    margin-bottom: 1rem;
}

.product-grid-title {
    font-size: 1rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
    color: var(--primary-text-color);
}

.product-grid-prices {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: row;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.9rem;
}

.product-grid-card-link,
.product-grid-card-link:visited,
.product-grid-card-link:hover,
.product-grid-card-link:active {
    text-decoration: none;
    color: inherit;
}
.product-grid-price {
    color: var(--primary-text-color);
    font-weight: 800;
}

.product-grid-price-old {
    color: var(--secondary-text-color);
    font-weight: 400;
}

.product-grid-price-new {
    color: var(--primary-text-color);
    font-weight: 800;
}
