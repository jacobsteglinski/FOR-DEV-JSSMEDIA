:root {
    --primary-background-color: {{ settings.primary_background_color }};
    --secondary-background-color: {{ settings.secondary_background_color }};
    --primary-text-color: {{ settings.primary_text_color }};
}

html {
    background-color: var(--primary-background-color); 
}

body {
    margin: 0;
    padding: 0;
}
