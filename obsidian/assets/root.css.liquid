:root {
    --primary-background-color: {{ settings.primary_background_color }};
    --secondary-background-color: {{ settings.secondary_background_color }};
    --primary-text-color: {{ settings.primary_text_color }};
    --secondary-text-color: {{ settings.secondary_text_color }};
}

html {
    background-color: var(--primary-background-color); 
    overflow: hidden;
}

body {
    margin: 0;
    padding: 0;
}

/* MISC */
.hidden {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
}

.shown {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.75s ease;
}