.hero-content {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

.hero-text-wrapper {
    display: flex;
    gap: 2px; /* Reduced gap between letters */
}

.hero-text-wrapper span {
    font-size: 2rem;
    color: blue;
    transition: transform 0.3s ease;
    display: inline-block;
    animation: rotateY 0.5s ease-out forwards;
    animation-delay: calc(var(--index) * 0.15s);
    opacity: 0;
}

.hero-text-wrapper .space {
    width: 10px; /* Adjust this for the space width */
}

@keyframes rotateY {
    0% {
        transform: rotateY(90deg);
        opacity: 0;
    }
    50% {
        opacity: 1;
    }
    100% {
        transform: rotateY(0deg);
        opacity: 1;
    }
}
