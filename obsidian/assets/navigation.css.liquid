/* FONTS */
.nav-font {
    font-family: "Roboto Slab", serif;
    font-optical-sizing: auto;
    font-weight: 900;
    font-style: normal;
}

/* Navigation Bar */
.navigation-bar {
    display: flex;
    justify-content: space-between; 
    align-items: center;
    padding: 0 2vw;
    height: 15vh;
}

.brand-logo {
    cursor: pointer;
    width: 6vw;
    height: auto;
}

.nav-list {
    display: flex;
    gap: 1.5vw;
    list-style: none;
    flex-grow: 1;
    justify-content: center;
    margin: 0;
    padding: 0;
}

.nav-item {
    font-size: 1.25vw;
    cursor: pointer;
    color: var(--primary-text-color);
    text-decoration: none;
    position: relative;
}

.nav-item::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.2em;
    width: 0;
    height: 0.2vh; 
    background-color: {{ settings.loading_navbar_underline_color }};
    transition: width 0.5s ease; 
}

.nav-item:hover::after {
    width: 100%; 
}
.cart-icon {
    width: 2vw;
    height: auto;
    cursor: pointer;
}

/* Sidebar and Hamburger Menu */
.hamburger-menu {
    position: absolute;
    top: 2vh;
    left: 2vw;
    background: none;
    border: none;
    color: {{ settings.loading_hamburger_menu_icon_color }};
    font-size: 2em;
    cursor: pointer;
    z-index: 1000;
    display: none;
    transform: scale(0.75);
    transition: transform 0.5s ease;
}

.sidebar {
    position: fixed;
    top: 0;
    left: -100%;
    width: 40%; 
    height: 100%;
    background-color: {{ settings.secondary_background_color }};
    color: {{ settings.primary_text_color }};
    box-shadow: 2px 0 5px rgba(0, 0, 0, 0.5);
    transition: left 0.5s ease-in-out;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 5vh;
    z-index: 999;
}

.sidebar.open {
    left: 0;
}

.nav-list-mobile {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2vh;
}

.nav-item-mobile {
    font-size: 1.5em;
    text-decoration: none;
    color: var(--primary-text-color);
    text-align: center;
}

/* Media Query for Mobile Devices */
@media screen and (max-width: 800px) {
    .hamburger-menu {
        display: block !important; 
    }

    .navigation-bar {
        display: none !important;
    }

    .brand-logo-mobile {
        width: 20vw !important;
    }

    .nav-item-mobile {
        font-size: 3vw !important;
    }
}

@media screen and (min-width: 801px) {
    .sidebar {
        display: none !important; 
    }
}

@media screen and (min-width: 801px) and (max-width: 1200px) {
    .nav-item {
        font-size: 2vw !important;
    }

    .cart-icon {
        width: 3vw !important;
    }
}

@media screen and (max-width: 550px) {
    .hamburger-menu {
        transform: scale(0.5) !important;
    }
}

@media screen and (max-width: 1600px) {
    .brand-logo {
        width: 8vw !important;
    }
}