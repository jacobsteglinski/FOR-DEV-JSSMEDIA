    {% comment %} /* General */
html {
    background-color: #252525; 
}

body {
    margin: 0;
    padding: 0;
}

/* FONTS */
.nav-font {
    font-family: "Roboto Slab", serif;
    font-optical-sizing: auto;
    font-weight: 900;
    font-style: normal;
}

/* Navigation Bar */
.navigation-bar {
    display: flex;
    justify-content: space-between; 
    align-items: center;
    padding: 0 2vw;
    height: 15vh;
}

.brand-logo {
    cursor: pointer;
    width: 6vw;
    height: auto;
}

.nav-list {
    display: flex;
    gap: 1.5vw;
    list-style: none;
    flex-grow: 1;
    justify-content: center;
    margin: 0;
    padding: 0;
}

.nav-item {
    font-size: 1.25vw;
    cursor: pointer;
    color: #f3f3f3;
    text-decoration: none;
    position: relative;
}

.nav-item::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.2em;
    width: 0;
    height: 0.2vh; 
    background-color: #ffffff;
    transition: width 0.5s ease; 
}

.nav-item:hover::after {
    width: 100%; 
}
.cart-icon {
    width: 2vw;
    height: auto;
    cursor: pointer;
}

/* Sidebar and Hamburger Menu */
.hamburger-menu {
    position: absolute;
    top: 2vh;
    left: 2vw;
    background: none;
    border: none;
    color: #fff;
    font-size: 2em;
    cursor: pointer;
    z-index: 1000;
    display: none;
    transform: scale(0.75);
    transition: transform 0.5s ease;
}

.sidebar {
    position: fixed;
    top: 0;
    left: -100%;
    width: 40%; 
    height: 100%;
    background-color: #333;
    color: #fff;
    box-shadow: 2px 0 5px rgba(0, 0, 0, 0.5);
    transition: left 0.5s ease-in-out;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 5vh;
    z-index: 999;
}

.sidebar.open {
    left: 0;
}

.nav-list-mobile {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2vh;
}

.nav-item-mobile {
    font-size: 1.5em;
    text-decoration: none;
    color: #fff;
    text-align: center;
}

.nav-item-mobile:hover {
    color: #ccc;
}

/* Media Query for Mobile Devices */
@media (max-width: 800px) {
    .hamburger-menu {
        display: block;
    }

    .navigation-bar {
        display: none;
    }
    .brand-logo-mobile {
        width: 20vw;
    }
    .nav-item-mobile {
        font-size: 3vw;
    }
}

@media (min-width: 801px) {
    .sidebar {
        display: none; 
    }
}
@media (min-width: 801px) and (max-width: 1200px) {
    .nav-item {
        font-size: 2vw;
    }
    .cart-icon {
        width: 3vw;
    }
}
@media (max-width: 550px) {
    .hamburger-menu {
        transform: scale(0.5);
    }
}
@media (max-width: 1600px) {
    .brand-logo {
        width: 8vw;
    }
} {% endcomment %}

{% comment %} document.getElementById('hamburger-menu').addEventListener('click', () => {
    const sidebar = document.getElementById('sidebar');
    sidebar.classList.toggle('open');
}); {% endcomment %}