{% schema %}
    {
      "name": "LOADING PAGE",
      "tag": "section",
      "class": "loading-section",
      "settings": [
        {
          "type": "text",
          "id": "hero_title",
          "label": "Heading Text",
          "default": "Welcome to Our Store"
        }
      ],
      "presets": [
        {
          "name": "LOADING PAGE (HAS TO BE ON TOP)",
          "category": "1. Suggested"
        }
      ]
    }
    {% endschema %}
    
{{ 'loading.css' |  asset_url |  stylesheet_tag }}

    <div class="loading-content">
      {% if settings.favicon %}
        <img src="{{ settings.favicon |  image_url: width: 200 }}" alt="Brand Logo">
      {% endif %}
      <div class="loading-text-wrapper" data-loading-title="{{ section.settings.hero_title }}">
        {% comment %} Here, the hero_titles content will be shown dynamically {% endcomment %}
      </div>
    </div>